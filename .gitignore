# Local dev only — fix RLS recursion caused by Supabase local's stricter
# row_security enforcement. These policies differ from production and must
# never be pushed to the remote database.
# Existing local-only files use the 20260601* date prefix (kept for backwards compat).
# New local-only migrations must use the *_local_*.sql naming convention instead.
supabase/migrations/20260601*.sql
supabase/migrations/*_local_*.sql
supabase/seed_demo_data.sql